# Supabase - https://supabase.com/dashboard/project/<project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Claude API - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# NHN Cloud SMS (선택)
NHN_APP_KEY=
NHN_SECRET_KEY=
NHN_SENDER_PHONE=

# Instagram Graph API (선택)
# Meta 개발자 콘솔 → 앱 → Instagram Basic Display → Access Token
INSTAGRAM_GRAPH_TOKEN=
# 인스타그램 비즈니스 계정 ID (Graph API 탐색기에서 /me?fields=id 로 확인)
INSTAGRAM_ACCOUNT_ID=
# 웹훅 검증 토큰 (임의 문자열, Meta 콘솔에 동일하게 입력)
INSTAGRAM_VERIFY_TOKEN=
# 앱 시크릿 (선택 — 웹훅 서명 검증용)
INSTAGRAM_APP_SECRET=

# OpenAI (무드보드 생성 - gpt-image-1)
OPENAI_API_KEY=sk-...

# Toss Payments - https://developers.tosspayments.com/
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...

# 관리자 이메일 (admin 페이지 접근)
ADMIN_EMAIL=whddn1545@gmail.com

# Vercel Cron 인증 시크릿 (vercel.json cron 보호용)
CRON_SECRET=your-random-secret
